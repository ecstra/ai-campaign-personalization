# Copy this file to .env and fill in the values
# cp .env.example .env

# ── Database (Supabase) ─────────────────────────────────────────
DATABASE_URI=postgresql://postgres:PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres

# ── LLM (DeepSeek / Groq / Google / OpenRouter) ────────────────
# moonlight-ai supports several providers. Set LLM_SOURCE to the alias
# (e.g. "deepseek", "groq", "openrouter") or a raw OpenAI-compatible URL.
LLM_SOURCE=deepseek
LLM_API_KEY=sk-your_deepseek_api_key
LLM_MODEL=deepseek-chat

# ── LlamaParse (document upload extraction) ────────────────────
# Used by the /campaigns/{id}/document endpoint to parse uploaded PDFs,
# DOCX, PPTX, etc. into markdown for LLM summarization.
LLAMA_CLOUD_API_KEY=llx-your_llamaparse_api_key

# ── Email generation quality gate ──────────────────────────────
# When true (default), every generated email runs through a second LLM
# critic pass. If the critic flags violations of banned patterns, the
# email is regenerated once with the violations injected as guidance.
# Doubles LLM cost per email (still sub-cent). Set to "false" to disable
# and fall back to single-pass generation.
CRITIQUE_ENABLED=true

# ── Google OAuth ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://lvoutreach.duckdns.org/auth/callback

# ── Security (generate these, don't copy as-is) ────────────────
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── Gmail ───────────────────────────────────────────────────────
GMAIL_DAILY_SEND_LIMIT=450
GMAIL_INTER_SEND_DELAY_MS=200
REPLY_CHECK_INTERVAL_SECONDS=300

# ── CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=https://lvoutreach.duckdns.org
